# Required: geographic coordinates for solar clock calculations
HAA_LATITUDE=59.33
HAA_LONGITUDE=18.07

# Optional: IANA timezone (defaults to UTC)
HAA_TIMEZONE=Europe/Stockholm

# Optional: SQLite database path (defaults to data/data.sqlite)
HAA_DB_PATH=data/data.sqlite

# Optional: HTTP listen port (defaults to 8080)
HAA_PORT=8080
