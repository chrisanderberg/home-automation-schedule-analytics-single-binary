{
  "name": "single_holding_bucket",
  "control": {
    "controlId": "mode-hold",
    "controlType": "radio buttons",
    "numStates": 2,
    "stateLabels": ["off", "on"]
  },
  "registeredModels": ["weekday"],
  "aggregate": {
    "modelId": "weekday",
    "quarterIndex": 12,
    "holdings": [
      { "clock": "utc", "state": 0, "bucket": 0, "value": 300000 }
    ]
  },
  "reportRequests": [
    {
      "name": "no_smoothing_no_damping",
      "query": {
        "clock": "utc",
        "smoothing": "none",
        "holdingDampingMillis": "none",
        "transitionDampingCount": "none",
        "include": ["raw", "rates"]
      },
      "expect": {
        "occupancyBucketSumsToOne": true,
        "preferenceBucketSumsToOne": true,
        "exactSeries": [
          { "section": "occupancy", "state": 0, "bucket": 0, "want": 1.0, "tolerance": 0.000001 },
          { "section": "occupancy", "state": 1, "bucket": 0, "want": 0.0, "tolerance": 0.000001 },
          { "section": "preference", "state": 0, "bucket": 0, "want": 1.0, "tolerance": 0.000001 },
          { "section": "rate", "fromState": 0, "toState": 1, "bucket": 0, "want": 0.0, "tolerance": 0.000001 }
        ],
        "zeroSeries": [
          { "section": "rate", "fromState": 0, "toState": 1, "bucket": 0 }
        ]
      }
    }
  ]
}
